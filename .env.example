# ============================================
# TRADING BOTS — Шаблон переменных окружения
# Скопируй в .env и заполни свои значения
# НИКОГДА не коммить .env в git!
# ============================================

# === KALSHI BOT ===
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_PRIVATE_KEY_PATH=./keys/kalshi_private.pem
KALSHI_ENV=demo                         # demo | prod

# === CRYPTO FUTURES BOT ===
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true                    # true = testnet (безопасно)
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=true

# === РЕЖИМ ТОРГОВЛИ ===
# ВАЖНО: оба флага должны быть false для реальной торговли
LIVE_TRADING=false                      # false = paper trading
DRY_RUN=true                            # true = логируем ордера, не отправляем

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_CHAT_ID=your_chat_id_here

# === БАЗА ДАННЫХ ===
DATABASE_URL=sqlite+aiosqlite:///./trading.db
# Для продакшн: postgresql+asyncpg://user:password@localhost/trading

# === МОНИТОРИНГ ===
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
