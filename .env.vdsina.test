# ============================================================
# .env.vdsina.test — Шаблон для ТЕСТА на VDSina (1 GB RAM)
# ============================================================
# 1. cp .env.vdsina.test .env
# 2. nano .env — заполни ВСЕ значения
# 3. chmod 600 .env
# ============================================================

# === KALSHI BOT (ОТКЛЮЧЁН ДЛЯ ТЕСТА) ===
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PATH=/app/keys/kalshi_private.pem
KALSHI_ENV=demo

# === CRYPTO FUTURES BOT (ОСНОВНОЙ ДЛЯ ТЕСТА) ===
BYBIT_API_KEY=ТВОЙ_BYBIT_API_KEY
BYBIT_API_SECRET=ТВОЙ_BYBIT_API_SECRET
BYBIT_TESTNET=true                    # ОБЯЗАТЕЛЬНО true для теста!
# Binance (не используется, оставлено для совместимости)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# BINANCE_TESTNET=true

# === РЕЖИМ ТОРГОВЛИ (БЕЗОПАСНЫЕ ЗНАЧЕНИЯ ДЛЯ ТЕСТА) ===
LIVE_TRADING=false                      # false = paper trading
DRY_RUN=true                            # true = логируем, не отправляем

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=ТВОЙ_TELEGRAM_BOT_TOKEN
TELEGRAM_ALLOWED_CHAT_ID=ТВОЙ_CHAT_ID

# === БАЗА ДАННЫХ (SQLite в Docker volume) ===
DATABASE_URL=sqlite+aiosqlite:////app/data/crypto.db

# === МОНИТОРИНГ ===
LOG_LEVEL=INFO

# === BACKBLAZE B2 (ОПЦИОНАЛЬНО ДЛЯ ТЕСТА) ===
# B2_APPLICATION_KEY_ID=
# B2_APPLICATION_KEY=
# B2_BUCKET_NAME=trading-backups