# ============================================================
# .env.vps.template — Шаблон для продакшн .env на VPS
# ============================================================
# 1. Скопируй этот файл в .env на VPS: cp .env.vps.template .env
# 2. Заполни ВСЕ значения (ничего не оставляй пустым!)
# 3. chmod 600 .env  (только владелец читает)
#
# ВНИМАНИЕ: Этот файл НЕ коммитится в git!
# На VPS он создаётся вручную или через GitHub Actions secrets
# ============================================================

# === KALSHI BOT ===
KALSHI_API_KEY=REPLACE_WITH_YOUR_KALSHI_API_KEY
KALSHI_PRIVATE_KEY_PATH=/app/keys/kalshi_private.pem
KALSHI_ENV=demo

# === CRYPTO FUTURES BOT ===
BINANCE_API_KEY=REPLACE_WITH_YOUR_BINANCE_API_KEY
BINANCE_API_SECRET=REPLACE_WITH_YOUR_BINANCE_API_SECRET
BINANCE_TESTNET=true
BYBIT_API_KEY=REPLACE_WITH_YOUR_BYBIT_API_KEY
BYBIT_API_SECRET=REPLACE_WITH_YOUR_BYBIT_API_SECRET
BYBIT_TESTNET=true

# === РЕЖИМ ТОРГОВЛИ ===
# ВАЖНО: Для paper trading (безопасно):
LIVE_TRADING=false
DRY_RUN=true
#
# Для LIVE торговли (ОПАСНО - реальные деньги!):
# LIVE_TRADING=true
# DRY_RUN=false
#
# НИКОГДА не ставь LIVE_TRADING=true и DRY_RUN=true одновременно!

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=REPLACE_WITH_YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_ALLOWED_CHAT_ID=REPLACE_WITH_YOUR_CHAT_ID

# === БАЗА ДАННЫХ ===
# SQLite (в Docker volume):
DATABASE_URL=sqlite+aiosqlite:////app/data/trading.db
#
# PostgreSQL (для продакшн - раскомментируй и заполни):
# DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/trading

# === МОНИТОРИНГ ===
LOG_LEVEL=INFO

# === BACKBLAZE B2 (для бэкапов) ===
B2_APPLICATION_KEY_ID=REPLACE_WITH_B2_KEY_ID
B2_APPLICATION_KEY=REPLACE_WITH_B2_APP_KEY
B2_BUCKET_NAME=trading-backups